# HobbyFi Vendor Copilot API - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED - Must be set for the application to work
# =============================================================================

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Database URL - PostgreSQL with asyncpg driver (required for production)
# Format: postgresql+asyncpg://user:password@host:port/database?sslmode=require
# For Aiven: postgresql+asyncpg://avnadmin:password@host:port/defaultdb?ssl=require
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/copilot_db?sslmode=require

# =============================================================================
# OPTIONAL - Have sensible defaults
# =============================================================================

# LLM Model to use (gemini-3.1-flash-lite is fast and cheap)
GEMINI_MODEL=gemini-3.1-flash-lite

# LLM Temperature (0.0 = deterministic, 1.0 = creative)
GEMINI_TEMPERATURE=0.2

# Maximum tokens in LLM response
GEMINI_MAX_OUTPUT_TOKENS=2048

# =============================================================================
# APP SETTINGS
# =============================================================================

# Application name
APP_NAME=HobbyFi Vendor Copilot API

# Environment: development | staging | production
APP_ENV=production

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS origins (comma-separated) - frontend URLs allowed to call the API
CORS_ORIGINS=https://your-frontend.example.com,https://admin.example.com

# =============================================================================
# AUTH / AUTHORIZATION (Future - currently header-based stubs)
# =============================================================================

# JWT Secret for token signing (generate with: openssl rand -hex 32)
# JWT_SECRET_KEY=your_jwt_secret_here

# JWT Algorithm
# JWT_ALGORITHM=HS256

# Token expiration (minutes)
# JWT_EXPIRE_MINUTES=30

# =============================================================================
# PROPOSAL SETTINGS
# =============================================================================

# How long proposals stay valid before auto-expiring (minutes)
PROPOSAL_TTL_MINUTES=30

# =============================================================================
# RATE LIMITING
# =============================================================================

# Requests per minute per IP
# RATE_LIMIT_REQUESTS=60

# Rate limit window (seconds)
# RATE_LIMIT_WINDOW=60

# =============================================================================
# OBSERVABILITY
# =============================================================================

# Enable structured JSON logging
# LOG_JSON=true

# OpenTelemetry endpoint (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# DEVELOPMENT ONLY - Do not set in production
# =============================================================================

# Use SQLite for local development (no external DB needed)
# DATABASE_URL=sqlite+aiosqlite:///./copilot_mock.db

# Skip auth for local testing
# DEV_MODE=true